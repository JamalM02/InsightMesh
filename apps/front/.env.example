PORT=5000

# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxx
CLERK_SECRET_KEY=sk_test_xxxxx

# Stripe Payments
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx
STRIPE_SECRET_KEY=sk_test_xxxxx

# Auto-injected by ecosystem.config.js in production (defaults for local dev)
GRPC_ACCOUNT_URL=0.0.0.0:50053

# Metabase public dashboard URL (embedded as iframe on /dashboard page)
# Generate in Metabase: Dashboard -> Sharing -> Enable sharing -> copy public link
# Local:  http://localhost:3000/public/dashboard/<UUID>
# Prod:   https://insightmesh.jmd-solutions.com/metabase/public/dashboard/<UUID>
NEXT_PUBLIC_METABASE_DASHBOARD_URL=http://localhost:3000/public/dashboard/<UUID>
